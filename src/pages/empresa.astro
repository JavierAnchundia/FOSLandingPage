---
import MainLayout from "../layouts/MainLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import CTASection from "../components/sections/CTASection.astro";
import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import { companyContent } from "../data/site";
import { clients } from "../data/clients";
---

<MainLayout title={companyContent.seo.title} description={companyContent.seo.description}>
  <PageHero
    eyebrow={companyContent.hero.eyebrow}
    title={companyContent.hero.title}
    description={companyContent.hero.description}
  />

  <section class="section-space">
    <Container className="grid gap-8 lg:grid-cols-2">
      <div class="card-surface rounded-[2rem] border border-white/70 p-8 md:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] section-label">Quienes somos</p>
        <p class="mt-5 text-base leading-8 text-slate-600">{companyContent.intro}</p>
      </div>
      <div class="grid gap-6">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500">Mision</p>
          <p class="mt-4 text-base leading-8 text-slate-600">{companyContent.mission}</p>
        </div>
        <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500">Vision</p>
          <p class="mt-4 text-base leading-8 text-slate-600">{companyContent.vision}</p>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-space pt-0">
    <Container className="space-y-12">
      <SectionTitle
        eyebrow="Principios"
        title="Valores que orientan nuestra forma de trabajar"
        description="La cultura de FOS se sustenta en principios que fortalecen la relacion con clientes, equipos y proyectos."
      />
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-5">
        {
          companyContent.values.map((value) => (
            <article class="card-surface rounded-[2rem] border border-white/70 p-7">
              <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{value.title}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">{value.description}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section-space pt-0">
    <Container className="space-y-10">
      <SectionTitle
        eyebrow="Clientes"
        title="Algunas organizaciones que forman parte de nuestra experiencia"
        description="La trayectoria de FOS se ha construido junto a clientes institucionales, comerciales e industriales en distintos tipos de proyecto."
      />
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          clients.map((client) => (
            <div class="rounded-[1.5rem] border border-slate-200 bg-white px-6 py-5 shadow-sm">
              <p class="text-lg font-semibold tracking-tight text-slate-900">{client.name}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <CTASection
    title={companyContent.cta.title}
    description={companyContent.cta.description}
    ctaLabel={companyContent.cta.cta.label}
    ctaHref={companyContent.cta.cta.href}
  />
</MainLayout>
