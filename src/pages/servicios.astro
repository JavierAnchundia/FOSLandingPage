---
import MainLayout from "../layouts/MainLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import CTASection from "../components/sections/CTASection.astro";
import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import { services } from "../data/services";
import { servicesPageContent } from "../data/site";
---

<MainLayout title={servicesPageContent.seo.title} description={servicesPageContent.seo.description}>
  <PageHero
    eyebrow={servicesPageContent.hero.eyebrow}
    title={servicesPageContent.hero.title}
    description={servicesPageContent.hero.description}
  />

  <section class="section-space">
    <Container className="space-y-12">
      <SectionTitle
        eyebrow={servicesPageContent.section.eyebrow}
        title={servicesPageContent.section.title}
        description={servicesPageContent.section.description}
      />
      <div class="grid gap-6 lg:grid-cols-2">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </Container>
  </section>

  <CTASection
    title={servicesPageContent.cta.title}
    description={servicesPageContent.cta.description}
    ctaLabel={servicesPageContent.cta.cta.label}
    ctaHref={servicesPageContent.cta.cta.href}
  />
</MainLayout>
