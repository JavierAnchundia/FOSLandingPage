---
import type { NavigationItem } from "../../data/navigation";

type Props = {
  items: NavigationItem[];
  mobile?: boolean;
};

const { items, mobile = false } = Astro.props;
---

<nav
  aria-label="Principal"
  class:list={[
    mobile ? "flex flex-col gap-2" : "hidden items-center gap-2 lg:flex",
  ]}
>
  {
    items.map((item) => (
      <a
        href={item.href}
        data-nav-link
        data-section={item.href.split("#")[1] ?? "inicio"}
        data-active="false"
        class:list={[
          mobile
            ? "rounded-2xl bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm data-[active=true]:bg-slate-900 data-[active=true]:text-white"
            : "rounded-full border border-transparent px-4 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100 hover:text-slate-950 data-[active=true]:border-slate-200 data-[active=true]:bg-slate-900 data-[active=true]:text-white data-[active=true]:shadow-[0_14px_30px_rgba(15,23,42,0.18)]",
        ]}
      >
        {item.label}
      </a>
    ))
  }
</nav>
