---
import type { NavigationItem } from "../../data/navigation";

type Props = {
  items: NavigationItem[];
  mobile?: boolean;
};

const { items, mobile = false } = Astro.props;
---

<nav
  aria-label="Principal"
  class:list={[
    mobile ? "flex flex-col gap-2" : "hidden items-center gap-1 lg:flex",
  ]}
>
  {
    items.map((item, index) => (
      <a
        href={item.href}
        data-nav-link
        data-section={item.href.split("#")[1] ?? "inicio"}
        data-active={index === 0 ? "true" : "false"}
        class:list={[
          mobile
            ? "rounded-2xl bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm data-[active=true]:bg-slate-900 data-[active=true]:text-white"
            : "rounded-full px-4 py-2 text-sm font-medium text-slate-600 hover:bg-white hover:text-slate-900 data-[active=true]:bg-slate-900 data-[active=true]:text-white data-[active=true]:hover:bg-slate-900 data-[active=true]:hover:text-white",
        ]}
      >
        {item.label}
      </a>
    ))
  }
</nav>
