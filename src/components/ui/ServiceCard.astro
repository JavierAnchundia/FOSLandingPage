---
import type { ServiceCategory } from "../../data/services";
import { getServiceIconKind } from "../../utils/helpers";
import FeatureIcon from "./FeatureIcon.astro";

type Props = {
  service: ServiceCategory;
  compact?: boolean;
};

const { service, compact = false } = Astro.props;
const icon = getServiceIconKind(service.title);
---

<article class="card-surface relative flex h-full flex-col overflow-hidden rounded-[2rem] border border-white/70 p-7 md:p-8">
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-sky-500/70 via-sky-300/30 to-transparent"></div>
  <div class="flex items-start justify-between gap-4">
    <div class="space-y-4">
      <span class="inline-flex rounded-full bg-slate-900/6 px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600">
        Categoria
      </span>
      <h3 class="text-wrap-balance text-2xl font-semibold tracking-tight text-slate-950">{service.title}</h3>
    </div>
    <span class="icon-badge mt-2 inline-flex h-12 w-12 flex-none items-center justify-center rounded-2xl text-white">
      <FeatureIcon kind={icon} />
    </span>
  </div>
  <p class="mt-5 text-sm leading-7 text-slate-600">{compact ? service.summary : service.description}</p>
  <div class="mt-6 border-t border-slate-200/80 pt-5">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Capacidades incluidas</p>
  </div>
  <ul class="mt-4 space-y-3 text-sm text-slate-500">
    {
      service.capabilities.map((capability) => (
        <li class="flex gap-3">
          <span class="mt-2 h-2 w-2 flex-none rounded-full bg-sky-700"></span>
          <span>{capability}</span>
        </li>
      ))
    }
  </ul>
</article>
