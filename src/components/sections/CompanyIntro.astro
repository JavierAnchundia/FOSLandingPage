---
import Container from "../ui/Container.astro";

type Props = {
  title: string;
  intro: string;
  approach?: string;
};

const { title, intro, approach } = Astro.props;
---

<section class="section-space">
  <Container className="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div class="space-y-5">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] section-label">Empresa</p>
      <h2 class="text-wrap-balance text-3xl font-semibold tracking-tight text-slate-950 md:text-5xl">{title}</h2>
      <p class="max-w-sm text-sm leading-7 text-slate-500">
        Una presentacion clara de la empresa, su enfoque y el valor que aporta en proyectos tecnicos.
      </p>
    </div>
    <div class="card-surface relative overflow-hidden rounded-[2rem] border border-white/70 p-8 md:p-10">
      <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-sky-400/70 via-sky-200/40 to-transparent"></div>
      <div class="space-y-6 text-base leading-8 text-slate-600">
        <p>{intro}</p>
        {approach && <p>{approach}</p>}
      </div>
    </div>
  </Container>
</section>
