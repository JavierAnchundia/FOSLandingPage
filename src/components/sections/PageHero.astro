---
import Container from "../ui/Container.astro";

type Props = {
  eyebrow: string;
  title: string;
  description: string;
};

const { eyebrow, title, description } = Astro.props;
---

<section class="hero-glow">
  <Container className="py-20 md:py-24">
    <div class="max-w-4xl space-y-6">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-300">{eyebrow}</p>
      <h1 class="text-4xl font-semibold tracking-tight text-white md:text-6xl">{title}</h1>
      <p class="max-w-3xl text-lg leading-8 text-slate-300">{description}</p>
    </div>
  </Container>
</section>
