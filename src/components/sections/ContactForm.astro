---
import Button from "../ui/Button.astro";
---

<div class="card-surface relative overflow-hidden rounded-[2rem] border border-white/70 p-8 md:p-10">
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-sky-500/70 via-sky-300/35 to-transparent"></div>
  <div class="space-y-4">
    <p class="text-sm font-semibold uppercase tracking-[0.28em] section-label">Contacto</p>
    <h2 class="text-3xl font-semibold tracking-tight text-slate-950">Cuentanos que necesita tu proyecto</h2>
    <p class="text-sm leading-7 text-slate-600">
      Comparte el alcance general y te contactaremos para revisar el siguiente paso.
    </p>
  </div>

  <form class="mt-8 space-y-5" action="#" method="post">
    <div class="grid gap-5 md:grid-cols-2">
      <label class="space-y-2 text-sm font-medium text-slate-700">
        <span>Nombre</span>
        <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none placeholder:text-slate-400 focus:border-slate-900 focus:shadow-[0_0_0_4px_rgba(59,130,246,0.08)]" type="text" name="name" placeholder="Nombre completo" />
      </label>
      <label class="space-y-2 text-sm font-medium text-slate-700">
        <span>Empresa</span>
        <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none placeholder:text-slate-400 focus:border-slate-900 focus:shadow-[0_0_0_4px_rgba(59,130,246,0.08)]" type="text" name="company" placeholder="Nombre de la empresa" />
      </label>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      <label class="space-y-2 text-sm font-medium text-slate-700">
        <span>Correo electronico</span>
        <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none placeholder:text-slate-400 focus:border-slate-900 focus:shadow-[0_0_0_4px_rgba(59,130,246,0.08)]" type="email" name="email" placeholder="correo@empresa.com" />
      </label>
      <label class="space-y-2 text-sm font-medium text-slate-700">
        <span>Telefono</span>
        <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none placeholder:text-slate-400 focus:border-slate-900 focus:shadow-[0_0_0_4px_rgba(59,130,246,0.08)]" type="tel" name="phone" placeholder="+593 ..." />
      </label>
    </div>

    <label class="space-y-2 text-sm font-medium text-slate-700">
      <span>Mensaje</span>
      <textarea class="min-h-[160px] w-full rounded-[1.5rem] border border-slate-200 bg-white px-4 py-3 outline-none placeholder:text-slate-400 focus:border-slate-900 focus:shadow-[0_0_0_4px_rgba(59,130,246,0.08)]" name="message" placeholder="Cuente brevemente su necesidad o proyecto."></textarea>
    </label>

    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <p class="text-xs leading-6 text-slate-500">
        Mientras mas contexto nos compartas, mejor podremos orientarte.
      </p>
      <Button type="submit" variant="dark">Enviar mensaje</Button>
    </div>
  </form>
</div>
