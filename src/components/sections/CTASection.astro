---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";

type Props = {
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
};

const { title, description, ctaLabel, ctaHref } = Astro.props;
---

<section class="section-space">
  <Container>
    <div class="overflow-hidden rounded-[2.5rem] bg-slate-950 px-8 py-12 shadow-2xl shadow-slate-900/10 md:px-12 md:py-16">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div class="max-w-3xl space-y-5">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-300">Siguiente paso</p>
          <h2 class="text-3xl font-semibold tracking-tight text-white md:text-5xl">{title}</h2>
          <p class="text-base leading-8 text-slate-300 md:text-lg">{description}</p>
        </div>
        <div>
          <Button href={ctaHref}>{ctaLabel}</Button>
        </div>
      </div>
    </div>
  </Container>
</section>
